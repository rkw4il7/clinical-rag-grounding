# Container backend — Postgres+pgvector and the LLM both from docker-compose.
# Use it:  docker compose --profile llm up -d  &&  cp .env.docker.example .env
# (Switch back to a LAN/remote backend by restoring those values in .env.)

# Vector store — the docker-compose `postgres` service on localhost.
PG_CONN_STR=postgresql://postgres:postgres@localhost:5432/corpus_rag

# Embedding model (runs in the host Python process, not a container).
EMBED_MODEL_ID=BAAI/bge-base-en-v1.5
# EMBEDDING_DIM=768

# Retrieval / grounding.
TOP_K=10
MIN_SCORE=0.35
CHUNK_TOKEN_MARGIN=16
INGEST_EMBED_BATCH_SIZE=32
OCR_ON=true

# Reranking (host process). Defaults shown.
# RERANK_CANDIDATES=20
# RERANK_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2

# LLM — the docker-compose `llm` service (llama.cpp server, OpenAI-compatible).
# llama.cpp serves whatever GGUF it loaded; the model name here is cosmetic.
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen2.5-3b-instruct
# The 3B model on CPU is slow to first token; bump if your generator times out.
LLM_TIMEOUT=180
# Increase if generated answers stop mid-sentence with a token-limit warning.
LLM_MAX_TOKENS=4096

# Corpus origins.
CORPUS_SOURCES=[{"adapter": "local_path", "root": "tests/data/**/*"}]

# GUI upload cap (MB) per batch; must be <= .streamlit/config.toml maxUploadSize.
UPLOAD_MAX_MB=200
