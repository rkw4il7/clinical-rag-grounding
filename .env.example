# Corpus RAG Explorer — environment (root spec.md §6). Copy to .env and edit.

# Vector store. Percent-encode special chars in the password.
PG_CONN_STR=postgresql://postgres:postgres@localhost:5432/corpus_rag

# Embedding model (sentence-transformers id). EMBEDDING_DIM is derived from the
# model at startup; set it ONLY as an optional fast-fail double-check.
EMBED_MODEL_ID=BAAI/bge-base-en-v1.5
# EMBEDDING_DIM=768

# Retrieval / grounding.
TOP_K=10
# Abstention floor (cosine similarity, 0..1): drop retrieved chunks scoring below
# this; if none qualify the app abstains instead of answering. 0.0 disables the
# floor. 0.35 is a reasonable illustrative default for bge-base-en-v1.5 — tune it
# per corpus/model from the eval harness rather than treating it as fixed.
MIN_SCORE=0.35
# Cap each chunk to (embedding model max tokens - this margin) so chunks are
# never silently truncated at embed time. Leaves room for special tokens.
CHUNK_TOKEN_MARGIN=16

# Reranking (used by the Streamlit UI): retrieve RERANK_CANDIDATES chunks by
# cosine, then a cross-encoder reorders them and the answer is grounded in the
# top-K. The cross-encoder downloads (~90 MB) on first run. Defaults shown.
# RERANK_CANDIDATES=20
# RERANK_MODEL_ID=cross-encoder/ms-marco-MiniLM-L-6-v2

# Local OpenAI-compatible generator endpoint (llama.cpp / vLLM / Ollama).
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=local-model

# Corpus origins: JSON array of {adapter, root|url} objects.
CORPUS_SOURCES=[{"adapter": "local_path", "root": "tests/data/**/*"}]
